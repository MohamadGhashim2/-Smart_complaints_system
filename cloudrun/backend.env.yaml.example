DJANGO_DEBUG: "false"
DJANGO_ALLOWED_HOSTS: "YOUR_BACKEND_HOST.run.app"
CORS_ALLOWED_ORIGINS: "https://YOUR_FRONTEND_HOST.run.app"
CSRF_TRUSTED_ORIGINS: "https://YOUR_BACKEND_HOST.run.app,https://YOUR_FRONTEND_HOST.run.app"
CORS_ALLOW_CREDENTIALS: "true"
DJANGO_TRUST_X_FORWARDED_PROTO: "true"
COMPLAINT_AI_SYNC: "false"
RUN_MIGRATIONS_ON_STARTUP: "false"
OPENAI_CHEAP_MODEL: "gpt-5-nano"
OPENAI_SUMMARY_MODEL: ""
OPENAI_CLASSIFIER_MODEL: ""
